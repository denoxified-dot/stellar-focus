# NASA API key, used by `npm run fetch-apod` to download real Astronomy Picture
# of the Day imagery. Copy this file to `.env` and paste your own key.
#
# Get a free key in ~30 seconds at https://api.nasa.gov/
# If unset, the fetch script falls back to NASA's shared DEMO_KEY (heavily rate
# limited: ~30 requests/hour, 50/day).
NASA_API_KEY=DEMO_KEY
